# Ambiente
CRM_ENV=production
CRM_DEBUG=false

# Segurança (trocar por valor longo e aleatório)
CRM_SECRET_KEY=troque_por_uma_chave_longa_e_unica

# Persistência (Railway com volume em /data)
CRM_DATA_FILE=/data/data.json
CRM_UPLOAD_DIR=/data/uploads

# Landing / segurança
CRM_ALLOWED_ORIGINS=https://uardon.com.br,https://www.uardon.com.br
TURNSTILE_SECRET_KEY=cole_a_chave_secreta_somente_no_railway

# Render (opcional)
# Em Render, mantenha os mesmos caminhos em /data com disco persistente montado.

# Banco PostgreSQL (Railway)
DATABASE_URL=postgresql://user:pass@host:5432/railway

# Turnstile (modo tolerante por padrao)
TURNSTILE_FAIL_OPEN=true
